{
  "name": "task-hub",
  "version": "0.1.0",
  "description": "REST API сервис учёта задач",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test:migrate": "cross-env DATABASE_URL=postgresql://task_hub:task_hub_password@localhost:7804/task_hub_test?schema=public prisma migrate deploy",
    "pretest": "npm run test:migrate",
    "test": "cross-env NODE_ENV=test DATABASE_URL=postgresql://task_hub:task_hub_password@localhost:7804/task_hub_test?schema=public vitest run",
    "test:watch": "cross-env NODE_ENV=test DATABASE_URL=postgresql://task_hub:task_hub_password@localhost:7804/task_hub_test?schema=public vitest"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "task-tracker",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "pg": "^8.22.0",
    "pino": "^9.7.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.1.0",
    "@types/supertest": "^7.2.1",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^10.1.0",
    "prisma": "^7.9.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
